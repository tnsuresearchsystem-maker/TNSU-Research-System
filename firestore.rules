rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is an admin
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Allow all authenticated users to read and write core data
    // In a production app, you might want to restrict write access to specific fields
    // or only allow users to write to their own campus's data.
    match /projects/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /publications/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /utilizations/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /personnel/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /mous/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /ips/{document=**} {
      allow read, write: if isAuthenticated();
    }

    match /faculty_stats/{document=**} {
      allow read, write: if isAuthenticated();
    }

    // Users collection
    match /users/{userId} {
      // Only Admin or the user themselves can read their user data
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == userId);
      // Only Admin can create users (or user themselves during migration, but we removed that need)
      allow create: if isAuthenticated() && (isAdmin() || request.auth.uid == userId);
      // Only Admin or the user themselves can update their profile
      // Note: A stricter rule would prevent users from changing their own role to 'Admin'
      allow update: if isAuthenticated() && (isAdmin() || (request.auth.uid == userId && request.resource.data.role == resource.data.role && request.resource.data.organization.id == resource.data.organization.id));
      // Only Admin can delete users
      allow delete: if isAdmin();
    }

    // System Logs collection
    match /system_logs/{logId} {
      // Admins can read logs
      allow read: if isAdmin();
      // Any authenticated user can write logs (to record their actions)
      allow create: if isAuthenticated();
      // Logs should be immutable
      allow update, delete: if false;
    }
  }
}
